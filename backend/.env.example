RCA_SEARCH_DEFAULT_LIMIT=10
RCA_SEARCH_MAX_LIMIT=50
RCA_CHUNK_MAX_CONTENT_CHARS=4000

RCA_LLM_API_KEY=
RCA_LLM_BASE_URL=
RCA_LLM_MODEL=gpt-4.1-mini
RCA_RAG_MAX_CONTEXT_CHARS=12000
